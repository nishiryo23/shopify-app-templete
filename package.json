{
  "name": "shopify-matri-harness",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "exceljs": "^4.4.0",
    "isbot": "^5.1.31",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite": "^6.3.6",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@openai/codex-sdk": "^0.114.0",
    "@playwright/test": "^1.54.2",
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "react-router build",
    "codex:shopify-review-loop": "node scripts/run-codex-shopify-review-loop.mjs",
    "dev": "shopify app dev",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.tsx,.mts,.cts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "setup": "pnpm run prisma:generate && pnpm run prisma:migrate:deploy",
    "shopify": "shopify",
    "start": "react-router-serve ./build/server/index.js",
    "test:contracts": "node --test --test-concurrency=4 tests/contracts/*.test.mjs",
    "test:smoke": "node scripts/validate-smoke-env.mjs && playwright test",
    "test:smoke:list": "playwright test --list",
    "typecheck": "react-router typegen && tsc --noEmit",
    "check": "pnpm run lint && pnpm run test:contracts && node scripts/check-architecture-guardrails.mjs && node scripts/check-adr-discipline.mjs && pnpm run typecheck && pnpm run build && pnpm run test:smoke:list"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  }
}
