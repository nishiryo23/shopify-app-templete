generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  shopDomain              String   @id
  offlineSessionId        String?  @unique
  encryptedOfflineSession Json?
  grantedScopes           String[]
  lastBootstrapAt         DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model WebhookInbox {
  id               String   @id @default(cuid())
  deliveryKey      String   @unique
  eventId          String
  shopDomain       String
  topic            String
  webhookId        String?
  subscriptionName String?
  rawBody          String?
  hmacHeader       String?
  createdAt        DateTime @default(now())
  processedAt      DateTime?
}

enum JobState {
  queued
  retryable
  leased
  completed
  dead_letter
}

enum ArtifactVisibility {
  private
}

model Job {
  id             String      @id @default(cuid())
  shopDomain     String
  kind           String
  dedupeKey      String?
  state          JobState    @default(queued)
  payload        Json
  attempts       Int         @default(0)
  maxAttempts    Int         @default(5)
  availableAt    DateTime    @default(now())
  leaseToken     String?
  leasedAt       DateTime?
  leaseExpiresAt DateTime?
  leasedBy       String?
  completedAt    DateTime?
  deadLetteredAt DateTime?
  lastError      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  attemptsLog    JobAttempt[]
  artifacts      Artifact[]

  @@index([state, availableAt])
  @@index([shopDomain, state, availableAt])
  @@index([shopDomain, kind, dedupeKey])
}

model JobLease {
  shopDomain     String   @id
  jobId          String?
  leaseToken     String?
  leaseExpiresAt DateTime?
  workerId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model JobAttempt {
  id             String   @id @default(cuid())
  jobId          String
  attemptNumber  Int
  workerId       String
  leaseToken     String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  outcome        String?
  errorMessage   String?
  leaseExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, attemptNumber])
  @@index([workerId, startedAt])
}

model Artifact {
  id             String             @id @default(cuid())
  jobId          String?
  shopDomain     String
  kind           String
  bucket         String
  objectKey      String
  contentType    String
  checksumSha256 String
  sizeBytes      Int?
  visibility     ArtifactVisibility @default(private)
  retentionUntil DateTime?
  deletedAt      DateTime?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  job            Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([bucket, objectKey])
  @@index([shopDomain, kind, createdAt])
}
