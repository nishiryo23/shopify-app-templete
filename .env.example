# Copy to `.env` and adjust values. See README.md "Runtime notes".
#
# --- Database (required for Prisma / `pnpm dev`) ---
# Create database first, e.g. `createdb shopify_app_template_dev`
# Default user is often your OS username when omitted from the URL.
DATABASE_URL="postgresql://127.0.0.1:5432/shopify_app_template_dev?schema=public"

# --- Crypto (recommended for local dev) ---
# Generate: openssl rand -base64 32  (must decode to exactly 32 bytes)
SHOP_TOKEN_ENCRYPTION_KEY=""
# Optional: add when implementing signed manifests / CSV provenance (see domain/provenance)
# PROVENANCE_SIGNING_KEY=""

# --- Shopify app ---
# Client ID（shopify.app.toml の client_id）。埋め込み UI 用に明示しておくと安全。
# SHOPIFY_API_KEY=
# `shopify app dev` が注入することが多い。ローカルだけ動かす場合は Partner Dashboard の Secret。
# SHOPIFY_API_SECRET=
# shopify.app.toml の scopes をカンマ区切り（コードは split(",")）
# SCOPES="read_products,write_products"
# SHOPIFY_APP_URL は通常コメントアウトのまま。`shopify app dev` のトンネルが HOST 等で渡る（セッションごとに変わる）。
# scripts/shopify-dev-app-url.mjs が HOST を優先して SHOPIFY_APP_URL に反映する。

# --- Optional ---
# SHOP_CUSTOM_DOMAIN=
# Local worker defaults. `pnpm run dev:worker` fills these automatically when absent.
# AWS_REGION=ap-northeast-1
# QUEUE_POLL_INTERVAL_MS=1000
# QUEUE_LEASE_MS=30000
# S3_ARTIFACT_PREFIX=artifacts
# S3_ARTIFACT_BUCKET=local-artifacts
