# Copy to `.env` and adjust values. See README.md "Runtime notes".
#
# --- Database (required for Prisma / `pnpm dev`) ---
# Create database first, e.g. `createdb shopify_matri_dev`
# Default user is often your OS username when omitted from the URL.
DATABASE_URL="postgresql://127.0.0.1:5432/shopify_matri_dev?schema=public"

# --- Crypto (recommended for local dev) ---
# Generate: openssl rand -base64 32  (must decode to exactly 32 bytes)
SHOP_TOKEN_ENCRYPTION_KEY=""
PROVENANCE_SIGNING_KEY=""

# --- Shopify app (`shopify app dev` often injects these; set manually if needed) ---
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SCOPES=
# SHOPIFY_APP_URL=

# --- Optional ---
# SHOP_CUSTOM_DOMAIN=
# S3_ARTIFACT_PREFIX=artifacts
# S3_ARTIFACT_BUCKET=local-artifacts
