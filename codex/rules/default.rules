# codex/rules/default.rules

# These are human-readable Codex safeguard rules for risky commands.
# Repo-internal architecture enforcement belongs in lint/tests, not here.

deny:
  - git push
  - gh pr merge
  - shopify app deploy
  - pnpm prisma migrate deploy
  - aws s3 rm --recursive
  - rm -rf

warn:
  - pnpm prisma migrate dev
  - docker compose down -v
  - terraform apply
